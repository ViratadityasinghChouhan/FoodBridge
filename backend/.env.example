NODE_ENV=development
PORT=5002
MONGO_URI=mongodb://127.0.0.1:27017/foodbridge
JWT_SECRET=change_me
JWT_EXPIRE=30d
CLIENT_URL=http://localhost:5002
API_URL=http://localhost:5002

# Google OAuth Web Client ID, from Google Cloud Console.
GOOGLE_CLIENT_ID=

# SMTP settings are required to send real verification emails.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=your@gmail.com,
# SMTP_PASS=your_gmail_app_password, SMTP_FROM=FoodBridge <your@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Twilio settings are required to send real phone OTP SMS.
# Phone numbers should be E.164 format, for example +919876543210.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Keep true for local testing without SMTP/Twilio. Set false in production.
DEV_OTP_FALLBACK=true
